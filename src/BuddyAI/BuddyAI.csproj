<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows7.0</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>buddyai_flat.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="buddyai_flat.ico" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Markdig" Version="1.1.1" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3856.49" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="UIAutomationTypes">
      <HintPath>..\..\AutomationSupport\UIAutomationTypes.dll</HintPath>
    </Reference>
    <Reference Include="UIAutomationClient">
      <HintPath>..\..\AutomationSupport\UIAutomationClient.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>
